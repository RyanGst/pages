{
  "name": "pages",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": ["apps/*"],
  "scripts": {
    "dev:landing": "bun run --filter landing dev",
    "dev:blog": "bun run --filter blog dev",
    "build:landing": "bun run --filter landing build",
    "build:blog": "bun run --filter blog build",
    "build": "bun run build:landing && bun run build:blog",
    "deploy:landing": "bun run --filter landing deploy",
    "deploy:blog": "bun run --filter blog deploy"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}